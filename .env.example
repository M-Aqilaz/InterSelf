DB_USER="postgres"
DB_PASSWORD=""
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="interself"

DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"
AUTH_SECRET="change-me"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NOTE: Prisma does not expand nested variables, so copy DATABASE_URL as a full string in your real .env
# Example: DATABASE_URL="postgresql://postgres:@localhost:5432/interself?schema=public"
# Google OAuth redirect URI for local development:
# http://localhost:3000/api/auth/google/callback
